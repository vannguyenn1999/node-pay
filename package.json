{
  "name": "pay",
  "version": "1.0.0",
  "description": "\"# node-pay\"",
  "homepage": "https://github.com/vannguyenn1999/node-pay#readme",
  "bugs": {
    "url": "https://github.com/vannguyenn1999/node-pay/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vannguyenn1999/node-pay.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "lint": "eslint src --ext js --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.js\" \"*.js\"",
    "clean": "rm -rf build && mkdir build",
    "build-babel": "babel ./src -d ./build/src",
    "build": "npm run clean && npm run build-babel",
    "production": "npm run build && node ./build/src/server.js",
    "dev": "nodemon --exec babel-node ./src/server.js"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@payos/node": "^2.0.5",
    "bcrypt": "^6.0.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.10",
    "@babel/core": "^7.22.10",
    "@babel/eslint-parser": "^7.22.10",
    "@babel/node": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.22.10",
    "@babel/preset-env": "^7.22.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.47.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4"
  }
}
